{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "models": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "provider": { "type": "string" },
          "model": { "type": "string" },
          "roles": {
            "type": "array",
            "items": { "type": "string" }
          },
          "capabilities": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": true
      }
    },
    "tabAutocompleteOptions": {
      "type": "object",
      "properties": {
        "disable": { "type": "boolean" },
        "debounceDelay": { "type": "number" },
        "multilineCompletions": {
          "type": "string",
          "enum": ["always", "never", "auto"]
        },
        "useCache": { "type": "boolean" },
        "disableInFiles": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
